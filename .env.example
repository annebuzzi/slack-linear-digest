# Linear personal API key (Settings → API → Personal API keys)
LINEAR_API_KEY=lin_api_xxx

# Slack user token with scopes: users:read, users:read.email, im:history, im:read,
# mpim:history, mpim:read, channels:history, groups:history, search:read, chat:write
SLACK_USER_TOKEN=xoxp-xxx

# Slack bot token with scopes: chat:write, im:write (to DM you)
SLACK_BOT_TOKEN=xoxb-xxx

# Your email (used to resolve Slack user id)
MY_EMAIL=anne.buzzi@archive.com

# How many hours back to look for unanswered Slack messages
IGNORED_LOOKBACK_HOURS=48
